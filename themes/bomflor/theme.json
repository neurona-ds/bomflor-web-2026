{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "custom": true,
      "customGradient": true,
      "defaultPalette": false,
      "palette": [
        { "slug": "ink",        "color": "#141412",             "name": "Ink" },
        { "slug": "ink-soft",   "color": "#3C3C38",             "name": "Ink Soft" },
        { "slug": "ink-muted",  "color": "rgba(20,20,18,0.4)",  "name": "Ink Muted" },
        { "slug": "paper",      "color": "#F8F6F1",             "name": "Paper" },
        { "slug": "paper-warm", "color": "#F0EDE6",             "name": "Paper Warm" },
        { "slug": "white",      "color": "#FFFFFF",             "name": "White" },
        { "slug": "lime",       "color": "#ABD037",             "name": "Lime" },
        { "slug": "lime-deep",  "color": "#799721",             "name": "Lime Deep" },
        { "slug": "lime-dark",  "color": "#3D4B11",             "name": "Lime Dark" },
        { "slug": "wa-green",   "color": "#25D366",             "name": "WhatsApp Green" }
      ]
    },
    "typography": {
      "customFontSize": true,
      "defaultFontSizes": false,
      "fontSizes": [
        { "slug": "micro", "size": "0.56rem",  "name": "Micro" },
        { "slug": "xs",    "size": "0.62rem",  "name": "XS" },
        { "slug": "sm",    "size": "0.72rem",  "name": "SM" },
        { "slug": "base",  "size": "0.84rem",  "name": "Base" },
        { "slug": "md",    "size": "1rem",     "name": "MD" },
        { "slug": "lg",    "size": "1.2rem",   "name": "LG" },
        { "slug": "xl",    "size": "1.5rem",   "name": "XL" },
        { "slug": "2xl",   "size": "clamp(1.9rem, 6vw, 2.8rem)",  "name": "2XL" },
        { "slug": "hero",  "size": "clamp(2.8rem, 11vw, 5.5rem)", "name": "Hero" }
      ],
      "fontFamilies": [
        {
          "slug": "display",
          "name": "Cormorant Garamond",
          "fontFamily": "'Cormorant Garamond', Georgia, serif"
        },
        {
          "slug": "ui",
          "name": "Jost",
          "fontFamily": "'Jost', system-ui, sans-serif"
        }
      ]
    },
    "spacing": {
      "customSpacingSize": true,
      "spacingSizes": [
        { "slug": "section-mobile",  "size": "3.5rem",  "name": "Section Mobile" },
        { "slug": "section-desktop", "size": "5.5rem",  "name": "Section Desktop" },
        { "slug": "gutter",          "size": "1.25rem", "name": "Gutter" },
        { "slug": "gutter-desktop",  "size": "3.5rem",  "name": "Gutter Desktop" }
      ],
      "units": ["px", "rem", "em", "%", "vh", "vw"]
    },
    "custom": {
      "borderRadius": {
        "sharp":  "1px",
        "subtle": "2px",
        "pill":   "20px",
        "circle": "9999px"
      }
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1440px"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--paper)",
      "text": "var(--wp--preset--color--ink)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--ui)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "0"
    }
  },
  "templateParts": [
    { "name": "header",          "title": "Header",          "area": "header" },
    { "name": "header-minimal",  "title": "Header Minimal",  "area": "header" },
    { "name": "footer",          "title": "Footer",          "area": "footer" },
    { "name": "footer-minimal",  "title": "Footer Minimal",  "area": "footer" },
    { "name": "mobile-cart-bar", "title": "Mobile Cart Bar", "area": "uncategorized" }
  ],
  "customTemplates": [
    { "name": "front-page",         "title": "Front Page",        "postTypes": ["page"] },
    { "name": "page-faqs",          "title": "Page: FAQs",        "postTypes": ["page"] },
    { "name": "page-cart",          "title": "Page: Cart",        "postTypes": ["page"] },
    { "name": "page-checkout",      "title": "Page: Checkout",    "postTypes": ["page"] },
    { "name": "order-confirmation", "title": "Order Confirmation","postTypes": ["page"] },
    { "name": "page-account",       "title": "Page: My Account",  "postTypes": ["page"] },
    { "name": "page-register",      "title": "Page: Register",     "postTypes": ["page"] }
  ]
}
